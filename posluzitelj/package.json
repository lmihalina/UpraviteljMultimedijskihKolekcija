{
  "name": "zadaca_01",
  "version": "1.0.0",
  "description": "Projekt zadace 1 is kolegija RWA",
  "main": "build/server.js",
  "type": "module",
  "scripts": {
    "pripremi": "npm link --save --package-lock true express  express-session cookie-parser sqlite3 sqlite cors jsonwebtoken nodemailer base32-encoding totp-generator",
    "compile": "tsc --watch false",
    "copy-files": "copyfiles -u 1 src/**/*.html src/**/*.css src/**/*.jpg 'src/**/*.js' build/",
    "clean": "rm -r build/*",
    "zadaca": "node build/server.js konfiguracija.csv",
    "server": "node build/server.js konfiguracija.csv",
    "start": "npm run server",
    "spider": "npm run pripremi && npm run server",
    "local": "npm run clean && npm run compile && npm run copy-files && npm run server",
    "debug": "npm run compile && npm run copy-files && node --enable-source-maps --inspect-brk=9229 build/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "angrm" : "rm -r angular/*",
    "angcp" : "cp -r ../angular/dist/zadaca_02/browser/* angular/"
  },
  "author": "Leonardo Mihalina",
  "license": "ISC",
  "dependencies": {
    "base32-encoding": "file:../../../../../../usr/lib/node_modules/base32-encoding",
    "cookie-parser": "file:../../../../../../usr/lib/node_modules/cookie-parser",
    "cors": "file:../../../../../../usr/lib/node_modules/cors",
    "express": "file:../../../../../../usr/lib/node_modules/express",
    "express-session": "file:../../../../../../usr/lib/node_modules/express-session",
    "jsonwebtoken": "file:../../../../../../usr/lib/node_modules/jsonwebtoken",
    "nodemailer": "file:../../../../../../usr/lib/node_modules/nodemailer",
    "sqlite": "file:../../../../../../usr/lib/node_modules/sqlite",
    "sqlite3": "file:../../../../../../usr/lib/node_modules/sqlite3",
    "totp-generator": "file:../../../../../../usr/lib/node_modules/totp-generator"
  }
}
